// =====================================================================
// Scholr — Prisma schema
// PostgreSQL. Run: npx prisma migrate dev --name init
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============

enum Role {
  STUDENT                // School student (legacy / default)
  COLLEGE_STUDENT        // Undergraduate / postgraduate
  TEACHER
  PARENT
  SCHOOL_ADMIN
  COLLEGE_ADMIN
  RECRUITER
  WORKING_PROFESSIONAL   // Industry professional
  SERVICE_PROVIDER       // Cook, driver, electrician, gym trainer, caretaker, etc.
  SUPER_ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum SessionType {
  POMODORO
  DEEP_WORK
  STUDY_BLOCK
  CUSTOM
}

enum FocusSessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
  PAUSED
}

enum ExamType {
  SCHOOL
  COLLEGE
  COMPETITIVE
  CODING
  APTITUDE
  MOCK
  CUSTOM
}

enum QuestionType {
  MCQ
  MULTI_SELECT
  DESCRIPTIVE
  CODING
  TRUE_FALSE
  FILL_BLANK
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADED
  LATE
  REJECTED
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
  FREELANCE
  GIG          // Labour, daily wage, domestic services
}

enum JobCategory {
  TECH               // Software, IT, data
  PROFESSIONAL       // Office, business, finance
  EDUCATION          // Teaching, tutoring
  HEALTHCARE         // Medical, nursing
  DRIVER             // Driver, delivery
  COOK               // Cook, chef, kitchen helper
  HOUSEHOLD          // Maid, cleaner, caretaker
  SECURITY           // Security guard, watchman
  LABOUR             // Construction, factory, daily wage
  ELECTRICIAN        // Electrician, plumber, carpenter
  GARDENER           // Gardening, landscaping
  BEAUTY             // Salon, beautician
  RETAIL             // Shop, store
  OTHER
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFERED
  REJECTED
  WITHDRAWN
  HIRED
}

enum NotificationType {
  SYSTEM
  ASSIGNMENT
  EXAM
  CHAT
  JOB
  AI_INSIGHT
  STREAK
  POST_LIKE
  POST_COMMENT
  FOLLOW
}

enum MoodLevel {
  TERRIBLE
  LOW
  NEUTRAL
  GOOD
  GREAT
}

enum SubscriptionTier {
  FREE
  PRO
  INSTITUTION
  ENTERPRISE
}

// ============== CORE: USERS & AUTH ==============

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  username          String?        @unique
  passwordHash      String?
  authProvider      AuthProvider   @default(LOCAL)
  googleId          String?        @unique
  role              Role           @default(STUDENT)
  firstName         String?
  lastName          String?
  avatarUrl         String?
  bio               String?
  headline          String?
  phone             String?
  // Extended profile
  dob               DateTime?
  gender            String?
  country           String?
  state             String?
  city              String?
  bannerUrl         String?        // Cover/banner image
  resumeUrl         String?
  skills            String[]       @default([])
  githubUrl         String?
  linkedinUrl       String?
  portfolioUrl      String?
  websiteUrl        String?
  profileData       Json?          // Role-specific structured data (school info, company info, etc.)
  onboardingDone    Boolean        @default(false)
  // Privacy settings — control which contact fields are public on profile
  showPhone         Boolean        @default(false)
  showEmail         Boolean        @default(false)
  showLocation      Boolean        @default(true)
  showDob           Boolean        @default(false)
  emailVerified     Boolean        @default(false)
  emailVerifyToken  String?
  suspendedAt       DateTime?
  suspendedUntil    DateTime?       // null = permanent if suspendedAt is set
  suspendedReason   String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  subscriptionTier  SubscriptionTier @default(FREE)
  institutionId     String?
  institution       Institution?   @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  lastLoginAt       DateTime?

  // Relations
  sessions          Session[]
  focusSessions     FocusSession[]
  studyPlans        StudyPlan[]
  aiChats           AIChat[]
  enrollments       Enrollment[]
  taughtClassrooms  Classroom[]    @relation("ClassroomTeacher")
  announcements     ClassroomAnnouncement[] @relation("AnnouncementAuthor")
  materials         ClassroomMaterial[]     @relation("MaterialAuthor")
  attendanceSessions AttendanceSession[]    @relation("AttendanceTeacher")
  attendanceRecords  AttendanceRecord[]
  submissions       Submission[]
  examAttempts      ExamAttempt[]
  notifications     Notification[]    @relation("UserNotifications")
  sentNotifications Notification[]    @relation("NotificationFromUser")
  sentMessages      Message[]      @relation("MessageSender")
  receivedMessages  Message[]      @relation("MessageReceiver")
  applications      Application[]
  postedJobs        Job[]          @relation("JobPoster")
  careerProfile     CareerProfile?
  moodLogs          MoodLog[]
  journalEntries    JournalEntry[]
  parentRelations   ParentStudent[] @relation("StudentRelation")
  studentRelations  ParentStudent[] @relation("ParentRelation")
  wellnessThreads   WellnessThread[] @relation("UserWellnessThreads")
  wellnessComments  WellnessComment[] @relation("UserWellnessComments")
  leaderboardEntries LeaderboardEntry[]
  streak            Streak?
  codeSubmissions   CodeSubmission[]
  tasks             Task[]
  personalExams     PersonalExam[]
  createdProblems   CodingProblem[] @relation("CreatedProblems")
  // Social
  posts             Post[]
  postLikes         PostLike[]
  comments          PostComment[]
  shares            PostShare[]
  followers         Follow[]        @relation("FollowedBy")
  following         Follow[]        @relation("Following")
  blockedUsers      Block[]         @relation("Blocker")
  blockedBy         Block[]         @relation("Blocked")
  certificates      Certificate[]
  reportsMade       Report[]        @relation("ReportReporter")
  reportsReviewed   Report[]        @relation("ReportReviewer")
  education         Education[]
  workExperiences   WorkExperience[]
  serviceProfile     ServiceProfile?         @relation("UserServiceProfile")
  serviceBookings    ServiceBooking[]        @relation("CustomerBookings")
  serviceReviews     ServiceReview[]         @relation("CustomerReviews")
  serviceFavorites   ServiceFavorite[]
  serviceReports     ServiceProviderReport[]


  @@index([role])
  @@index([institutionId])
  @@index([createdAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  revokedAt    DateTime?

  @@index([userId])
  @@index([expiresAt])
}

model Institution {
  id        String   @id @default(cuid())
  name      String
  type      String   // "school" | "college" | "coaching" | "corporate"
  domain    String?  @unique
  logoUrl   String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  classrooms Classroom[]
}

// ============== FOCUS MODE ==============

model FocusSession {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        SessionType         @default(POMODORO)
  status      FocusSessionStatus  @default(ACTIVE)
  plannedMin  Int                 // planned duration (minutes)
  actualMin   Int?                // actual completed minutes
  subject     String?             // optional tag e.g. "Calculus"
  notes       String?
  blockedApps String[]            @default([]) // ["instagram.com", "youtube.com"]
  distractions Int                @default(0)  // times user tried to navigate away
  startedAt   DateTime            @default(now())
  endedAt     DateTime?

  @@index([userId, startedAt])
  @@index([status])
}

model Streak {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  current     Int      @default(0)
  longest     Int      @default(0)
  lastActiveAt DateTime?
  updatedAt   DateTime @updatedAt
}

// ============== STUDY PLANS ==============

model StudyPlan {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  goal        String?
  startDate   DateTime
  endDate     DateTime
  generatedByAI Boolean @default(false)
  items       StudyPlanItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model StudyPlanItem {
  id          String   @id @default(cuid())
  planId      String
  plan        StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  title       String
  subject     String?
  durationMin Int
  scheduledAt DateTime
  completed   Boolean  @default(false)
  completedAt DateTime?

  @@index([planId, scheduledAt])
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  subject     String?
  priority    TaskPriority @default(MEDIUM)
  durationMin Int          @default(30)
  status      TaskStatus   @default(PENDING)
  date        DateTime     @db.Date
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, date])
  @@index([userId, status])
}

model PersonalExam {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  subject   String?
  examDate  DateTime @db.Date
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, examDate])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  DONE
  SKIPPED
}

// ============== AI ==============

model AIChat {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String      @default("New chat")
  context   String?     // optional system-context tag e.g. "career", "math"
  messages  AIMessage[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId, updatedAt])
}

model AIMessage {
  id        String   @id @default(cuid())
  chatId    String
  chat      AIChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      String   // "user" | "assistant" | "system"
  content   String   @db.Text
  tokens    Int?
  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
}

// ============== CLASSROOMS / LMS ==============

model Classroom {
  id            String       @id @default(cuid())
  name          String
  code          String       @unique // join code
  description   String?
  subject       String?
  bannerColor   String?
  meetingLink   String?
  grade         String?
  schedule      String?
  archived      Boolean      @default(false)
  teacherId     String
  teacher       User         @relation("ClassroomTeacher", fields: [teacherId], references: [id])
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])
  enrollments   Enrollment[]
  assignments   Assignment[]
  exams         Exam[]
  announcements ClassroomAnnouncement[]
  materials     ClassroomMaterial[]
  attendance    AttendanceSession[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([teacherId])
  @@index([institutionId])
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())

  @@unique([userId, classroomId])
  @@index([classroomId])
}

model Assignment {
  id          String           @id @default(cuid())
  classroomId String
  classroom   Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  title       String
  description String?          @db.Text
  attachments String[]         @default([])
  totalMarks  Int              @default(100)
  dueAt       DateTime
  status      AssignmentStatus @default(PUBLISHED)
  submissions Submission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([classroomId, dueAt])
}

model Submission {
  id           String           @id @default(cuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  content      String?          @db.Text
  attachments  String[]         @default([])
  status       SubmissionStatus @default(PENDING)
  marks        Int?
  feedback     String?
  submittedAt  DateTime?
  gradedAt     DateTime?
  createdAt    DateTime         @default(now())

  @@unique([assignmentId, userId])
  @@index([userId])
}

// ============== TESTS / EXAMS / CODING ==============

model Exam {
  id            String       @id @default(cuid())
  title         String
  description   String?
  type          ExamType     @default(SCHOOL)
  durationMin   Int          @default(60)
  totalMarks    Int          @default(100)
  startsAt      DateTime?
  endsAt        DateTime?
  classroomId   String?
  classroom     Classroom?   @relation(fields: [classroomId], references: [id])
  generatedByAI Boolean      @default(false)
  questions     Question[]
  attempts      ExamAttempt[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([type])
  @@index([classroomId])
}

model Question {
  id              String       @id @default(cuid())
  examId          String?
  exam            Exam?        @relation(fields: [examId], references: [id], onDelete: Cascade)
  type            QuestionType
  difficulty      Difficulty   @default(MEDIUM)
  prompt          String       @db.Text
  options         Json?        // for MCQ/multi-select
  correctAnswer   Json?        // string | string[] for descriptive/coding store rubric
  explanation     String?      @db.Text
  marks           Int          @default(1)
  topic           String?
  codingProblemId String?      @unique
  codingProblem   CodingProblem? @relation(fields: [codingProblemId], references: [id])
  createdAt       DateTime     @default(now())

  @@index([examId])
  @@index([type, difficulty])
}

model CodingProblem {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  statement    String        @db.Text
  difficulty   Difficulty    @default(MEDIUM)
  tags         String[]      @default([])
  starterCode  Json          // { python: "...", javascript: "...", ... }
  testCases    Json          // [{ input, expectedOutput, isHidden }]
  timeLimitMs  Int           @default(2000)
  memoryLimitMb Int          @default(128)
  status       ProblemStatus @default(APPROVED)
  createdById  String?
  createdBy    User?         @relation("CreatedProblems", fields: [createdById], references: [id])
  reviewNote   String?       // admin feedback on rejection
  question     Question?
  submissions  CodeSubmission[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt @default(now())

  @@index([difficulty])
  @@index([status])
  @@index([createdById])
}

enum ProblemStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model CodeSubmission {
  id          String        @id @default(cuid())
  problemId   String
  problem     CodingProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  language    String        // "python", "javascript"
  code        String        @db.Text
  verdict     CodeVerdict   @default(PENDING)
  passedTests Int           @default(0)
  totalTests  Int           @default(0)
  runtimeMs   Int?
  errorOutput String?       @db.Text
  results     Json?         // per-test-case details
  submittedAt DateTime      @default(now())

  @@index([userId])
  @@index([problemId])
  @@index([submittedAt])
}

enum CodeVerdict {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT
  RUNTIME_ERROR
  COMPILE_ERROR
}

model ExamAttempt {
  id         String    @id @default(cuid())
  examId     String
  exam       Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers    Json      // { questionId: answer }
  score      Float?
  startedAt  DateTime  @default(now())
  submittedAt DateTime?

  @@index([userId])
  @@index([examId])
}

// ============== JOBS / PLACEMENT ==============

model Job {
  id            String     @id @default(cuid())
  recruiterId   String
  recruiter     User       @relation("JobPoster", fields: [recruiterId], references: [id])
  title         String
  company       String
  location      String?
  remote        Boolean    @default(false)
  type          JobType    @default(FULL_TIME)
  category      JobCategory @default(OTHER)
  description   String     @db.Text
  requirements  String[]   @default([])
  skills        String[]   @default([])
  salaryMin     Int?
  salaryMax     Int?
  // Gig fields
  dailyWage     Int?       // Per day rate for gig work
  payPeriod     String?    // "per day" | "per hour" | "per month"
  contactPhone  String?    // Direct contact number for blue-collar listings
  currency      String     @default("INR")
  applications  Application[]
  postedAt      DateTime   @default(now())
  expiresAt     DateTime?
  isActive      Boolean    @default(true)

  @@index([type, isActive])
  @@index([category, isActive])
  @@index([recruiterId])
}

model Application {
  id          String            @id @default(cuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      ApplicationStatus @default(APPLIED)
  resumeUrl   String?
  coverLetter String?           @db.Text
  aiScore     Float?            // AI-computed fit score 0-100
  notes       String?
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, userId])
  @@index([userId])
  @@index([status])
}

model CareerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline    String?
  skills      String[] @default([])
  interests   String[] @default([])
  experience  Json?    // [{ title, company, from, to, description }]
  education   Json?    // [{ school, degree, from, to }]
  resumeUrl   String?
  portfolioUrl String?
  githubUrl   String?
  linkedinUrl String?
  updatedAt   DateTime @updatedAt
}

// ============== NOTIFICATIONS / MESSAGING ==============

model Notification {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  fromUserId   String?
  fromUser     User?            @relation("NotificationFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)
  type         NotificationType @default(SYSTEM)
  title        String
  body         String?
  link         String?
  read         Boolean          @default(false)
  createdAt    DateTime         @default(now())

  @@index([userId, read, createdAt])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId, receiverId, createdAt])
}

// ============== WELLNESS ==============

model MoodLog {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood      MoodLevel
  note      String?
  loggedAt  DateTime  @default(now())

  @@index([userId, loggedAt])
}

// ============== LEADERBOARDS ==============

model Leaderboard {
  id        String   @id @default(cuid())
  scope     String   // "global" | "classroom:<id>" | "contest:<id>"
  name      String
  entries   LeaderboardEntry[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([scope])
}

model LeaderboardEntry {
  id            String      @id @default(cuid())
  leaderboardId String
  leaderboard   Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  score         Float
  rank          Int?
  updatedAt     DateTime    @updatedAt

  @@unique([leaderboardId, userId])
  @@index([leaderboardId, score])
}

// ============================================
// SOCIAL — LinkedIn-style feed for students
// ============================================

model Post {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         PostType      @default(POST)
  content      String        @db.Text
  imageUrl     String?       // Optional image attachment
  visibility   PostVisibility @default(PUBLIC)
  // Metadata for achievements/certificates
  achievement  Json?         // { title, subject, score, date }
  certificate  Json?         // { title, issuer, credentialUrl }
  // Engagement counters (denormalized for fast feed reads)
  likeCount    Int           @default(0)
  commentCount Int           @default(0)
  shareCount   Int           @default(0)

  likes        PostLike[]
  comments     PostComment[]
  shares       PostShare[]
  reports      Report[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([visibility])
}

enum PostType {
  POST            // Regular post
  ACHIEVEMENT     // Exam/coding score achievement
  CERTIFICATE     // Certification earned
  MILESTONE       // Streak / level / badge
}

enum PostVisibility {
  PUBLIC          // Anyone signed in can see
  FOLLOWERS_ONLY  // Only followers
  PRIVATE         // Only the author
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
}

model PostComment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
}

model PostShare {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String                                  // Who's doing the following
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String                                  // Who's being followed
  following   User     @relation("FollowedBy", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Block {
  id         String   @id @default(cuid())
  blockerId  String   // Who blocked
  blocker    User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId  String   // Who got blocked
  blocked    User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Certificate {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  issuer         String   // "Scholr", "Coursera", "AWS", etc.
  credentialUrl  String?
  imageUrl       String?
  issuedAt       DateTime
  createdAt      DateTime @default(now())

  @@index([userId])
}

// ============================================
// MODERATION — reports + admin actions
// ============================================

model Report {
  id           String       @id @default(cuid())
  postId       String
  post         Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporterId   String
  reporter     User         @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reason       ReportReason
  details      String?      @db.Text
  status       ReportStatus @default(PENDING)
  reviewerId   String?
  reviewer     User?        @relation("ReportReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewNote   String?
  reviewedAt   DateTime?
  createdAt    DateTime     @default(now())

  @@index([status, createdAt])
  @@index([postId])
  @@unique([postId, reporterId])  // one user can only report a post once
}

enum ReportReason {
  SPAM
  HARASSMENT
  HATE_SPEECH
  INAPPROPRIATE
  MISINFORMATION
  COPYRIGHT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED_KEPT      // Admin reviewed, decided to keep the post
  REVIEWED_REMOVED   // Admin reviewed, removed the post
  DISMISSED          // Admin dismissed the report (false alarm)
}

// ============================================
// PROFESSIONAL PROFILE
// ============================================

model Education {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution String
  degree      String?   // "B.Tech", "M.Sc", "XII", etc.
  field       String?   // "Computer Science", "Physics", etc.
  startYear   Int?
  endYear     Int?
  current     Boolean   @default(false)
  grade       String?   // "9.2 CGPA", "85%", etc.
  description String?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

model WorkExperience {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     String
  role        String
  location    String?
  startDate   DateTime?
  endDate     DateTime?
  current     Boolean   @default(false)
  description String?   @db.Text
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// ============================================
// SERVICE MARKETPLACE
// For people offering services — cooks, drivers, electricians, gym trainers,
// caretakers, tutors, etc. Discoverable by anyone who needs them.
// ============================================
// ============================================
// CLASSROOM EXTENSIONS
// ============================================

model ClassroomAnnouncement {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  content     String    @db.Text
  pinned      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([classroomId, createdAt])
}

model ClassroomMaterial {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation("MaterialAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  description String?
  fileUrl     String?
  linkUrl     String?
  type        MaterialType @default(LINK)
  createdAt   DateTime  @default(now())

  @@index([classroomId, createdAt])
}

enum MaterialType {
  PDF
  VIDEO
  LINK
  IMAGE
  DOC
  OTHER
}

model AttendanceSession {
  id           String    @id @default(cuid())
  classroomId  String
  classroom    Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  teacherId    String
  teacher      User      @relation("AttendanceTeacher", fields: [teacherId], references: [id])
  date         DateTime  @db.Date
  topic        String?
  records      AttendanceRecord[]
  createdAt    DateTime  @default(now())

  @@unique([classroomId, date])
  @@index([classroomId])
}

model AttendanceRecord {
  id        String            @id @default(cuid())
  sessionId String
  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    AttendanceStatus  @default(ABSENT)
  note      String?
  markedAt  DateTime          @default(now())

  @@unique([sessionId, userId])
  @@index([userId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}
// ============== SERVICES MARKETPLACE ==============

enum ServiceCategory {
  DRIVER
  COOK
  SALON_BEAUTY
  HOUSEHOLD_HELP
  SECURITY_GUARD
  SHOP_RETAIL
  EDUCATION_TUTOR
  HEALTHCARE
  TECH_IT
  REPAIR_MAINTENANCE
  DELIVERY_LOGISTICS
  EVENT_SERVICES
  CLEANING_SERVICES
  OTHER
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  OFFLINE
  ON_LEAVE
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ServiceReportReason {
  FAKE_PROFILE
  SPAM
  INAPPROPRIATE
  FRAUD
  POOR_QUALITY
  HARASSMENT
  OTHER
}

model ServiceProfile {
  id              String              @id @default(cuid())
  userId          String              @unique
  user            User                @relation("UserServiceProfile", fields: [userId], references: [id], onDelete: Cascade)
  displayName     String
  category        ServiceCategory
  customCategory  String?
  bio             String?             @db.Text
  experienceYears Int                 @default(0)
  skills          String[]            @default([])
  hourlyRate      Float?
  fixedPrice      Float?
  priceUnit       String              @default("hour")
  currency        String              @default("INR")
  contactPhone    String?
  contactEmail    String?
  latitude        Float
  longitude       Float
  addressLine     String?
  city            String?
  state           String?
  pincode         String?
  serviceRadiusKm Int                 @default(10)
  availability    AvailabilityStatus  @default(AVAILABLE)
  isVerified      Boolean             @default(false)
  isActive        Boolean             @default(true)
  avgRating       Float               @default(0)
  totalReviews    Int                 @default(0)
  totalBookings   Int                 @default(0)
  portfolioImages String[]            @default([])
  bookings        ServiceBooking[]
  reviews         ServiceReview[]
  favoritedBy     ServiceFavorite[]
  reports         ServiceProviderReport[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([category])
  @@index([latitude, longitude])
  @@index([isActive, availability])
}

model ServiceBooking {
  id              String          @id @default(cuid())
  customerId      String
  customer        User            @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  providerId      String
  provider        ServiceProfile  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  status          BookingStatus   @default(PENDING)
  serviceAddress  String
  latitude        Float?
  longitude       Float?
  pincode         String?
  bookingDate     DateTime
  startTime       String?
  durationMinutes Int?
  notes           String?         @db.Text
  expectedPrice   Float?
  finalPrice      Float?
  providerNote    String?
  cancelReason    String?
  completedAt     DateTime?
  review          ServiceReview?
  chatThread      ServiceChat?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([customerId])
  @@index([providerId])
  @@index([status])
}

model ServiceReview {
  id            String          @id @default(cuid())
  bookingId     String          @unique
  booking       ServiceBooking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customerId    String
  customer      User            @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade)
  providerId    String
  provider      ServiceProfile  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  rating        Int
  comment       String?         @db.Text
  providerReply String?         @db.Text
  createdAt     DateTime        @default(now())

  @@index([providerId])
}

model ServiceFavorite {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId String
  provider   ServiceProfile  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@unique([userId, providerId])
}

model ServiceChat {
  id            String               @id @default(cuid())
  bookingId     String               @unique
  booking       ServiceBooking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customerId    String
  providerId    String
  messages      ServiceChatMessage[]
  lastMessageAt DateTime?
  createdAt     DateTime             @default(now())
}

model ServiceChatMessage {
  id        String      @id @default(cuid())
  chatId    String
  chat      ServiceChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  content   String      @db.Text
  read      Boolean     @default(false)
  createdAt DateTime    @default(now())

  @@index([chatId, createdAt])
}

model ServiceProviderReport {
  id         String              @id @default(cuid())
  providerId String
  provider   ServiceProfile      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User                @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason     ServiceReportReason
  details    String?             @db.Text
  status     String              @default("PENDING")
  reviewNote String?
  createdAt  DateTime            @default(now())

  @@unique([providerId, reporterId])
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  title     String?
  aiInsight String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model ParentStudent {
  id              String   @id @default(cuid())
  parentId        String
  parent          User     @relation("ParentRelation", fields: [parentId], references: [id], onDelete: Cascade)
  studentId       String
  student         User     @relation("StudentRelation", fields: [studentId], references: [id], onDelete: Cascade)
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  // Visibility permissions controlled by student
  allowAcademic   Boolean  @default(true)
  allowAttendance Boolean  @default(true)
  allowStress     Boolean  @default(true)
  allowAptitude   Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([parentId, studentId])
}

model WellnessChannel {
  id          String   @id @default(cuid())
  name        String   // e.g. "NEET Aspirants Support", "Anonymous Venting"
  description String?
  isAnonymous Boolean  @default(false)
  threads     WellnessThread[]
  createdAt   DateTime @default(now())
}

model WellnessThread {
  id          String   @id @default(cuid())
  channelId   String
  channel     WellnessChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  title       String
  content     String   @db.Text
  userId      String
  user        User     @relation("UserWellnessThreads", fields: [userId], references: [id], onDelete: Cascade)
  isAnonymous Boolean  @default(false)
  comments    WellnessComment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([channelId])
  @@index([userId])
}

model WellnessComment {
  id          String   @id @default(cuid())
  threadId    String
  thread      WellnessThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  content     String   @db.Text
  userId      String
  user        User     @relation("UserWellnessComments", fields: [userId], references: [id], onDelete: Cascade)
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([threadId])
  @@index([userId])
}