{
  "manifest_version": 3,
  "name": "Scholr Focus Blocker",
  "version": "1.0.0",
  "description": "Blocks distracting websites during your Scholr focus sessions.",
  "permissions": ["storage", "alarms", "declarativeNetRequest", "declarativeNetRequestFeedback"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_icon": "icons/icon128.png" },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
